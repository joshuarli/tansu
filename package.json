{
  "name": "tansu",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "bundle": "esbuild web/ts/main.ts --bundle --outfile=web/static/app.js --minify --format=esm --define:process.env.NODE_ENV='\"production\"'",
    "bundle-dev": "esbuild web/ts/main.ts --bundle --outfile=web/static/app.js --format=esm --define:process.env.NODE_ENV='\"development\"'",
    "test": "vitest run",
    "test-e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@joshuarli98/md-wysiwyg": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "^7.0.0-dev.20260401.1",
    "@vitest/coverage-v8": "4.1.4",
    "esbuild": "0.28.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.8.9",
    "oxfmt": "0.43.0",
    "oxlint": "1.58.0",
    "playwright": "^1.59.1",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": ">=25.9.0"
  },
  "packageManager": "pnpm@11.0.0-rc.3"
}
